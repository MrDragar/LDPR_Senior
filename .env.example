# Токен бота (должен иметь права сообщений и документов)
BOT_TOKEN=your_bot_token_here

# Токен группы для проверки подписки (должен иметь право groups)
GROUP_TOKEN=your_group_token_here

# ID сообщества, на которое нужно подписаться (число, без минуса)
GROUP_ID=123456789

# ID администратора ВКонтакте (число)
ADMIN_ID=987654321

# ID беседы для логов (если это чат, укажите peer_id, например 2000000001 для чата №1)
LOG_CHAT_ID=2000000001

# Путь к PDF файлу внутри контейнера
PDF_PATH=/app/pamphlet.pdf
